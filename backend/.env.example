PORT=5000
SQLITE_PATH=./payguard.sqlite
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# OTP Provider — plug in your key (Twilio / MSG91 / Fast2SMS)
OTP_PROVIDER=mock           # set to: twilio | msg91 | fast2sms | mock
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890
MSG91_AUTHKEY=your_msg91_key
MSG91_TEMPLATE_ID=your_template_id
FAST2SMS_KEY=your_fast2sms_key

# Aadhaar KYC Sandbox
AADHAAR_SANDBOX_URL=https://sandbox.in.gov.in/api/v1
AADHAAR_CLIENT_ID=your_client_id
AADHAAR_CLIENT_SECRET=your_client_secret

FRONTEND_URL=http://localhost:5173
NODE_ENV=development
